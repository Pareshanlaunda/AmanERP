# Supabase — https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — required on Vercel too (Settings → Environment Variables)
# Never expose in browser or NEXT_PUBLIC_* vars
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local only — for npm run migrate / db:setup (NOT needed on Vercel)
DATABASE_PASSWORD=your-db-password
# DATABASE_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:5432/postgres

# Future: advocate email (Resend)
# RESEND_API_KEY=

# --- Botbiz WhatsApp integration ---
# Generate a random string for webhook verification (same value in Botbiz if supported)
BOTBIZ_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Local debugging only — ignored in production even if set
# BOTBIZ_WEBHOOK_DEBUG=true

# Optional: one-time setup gate for /setup (first admin). Set before first deploy.
# SETUP_TOKEN=long-random-string

# Botbiz Developer API (lead WhatsApp chat panel)
BOTBIZ_API_KEY=
# WhatsApp Cloud phone number ID for Debt Free Lawyer (+919272394857) — required for get/send
BOTBIZ_PHONE_NUMBER_ID=
BOTBIZ_API_BASE_URL=https://dash.botbiz.io

# Optional: admin user UUID for auto-created WhatsApp leads (created_by)
# If unset, the first admin profile is used.
# WHATSAPP_SYSTEM_USER_ID=

# Optional: override Botbiz JSON field names (comma-separated aliases)
# BOTBIZ_FIELD_CLIENT_NAME=client_name,name
# BOTBIZ_FIELD_CLIENT_PHONE=phone,mobile
# BOTBIZ_FIELD_LOAN_AMOUNT=loan_amount,amount
# BOTBIZ_FIELD_LOAN_TYPE=loan_type,type
